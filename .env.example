# .env.example
# Template for Sprimal Hub environment variables.
# Copy this file to .env and fill in real values.
# NEVER commit your actual .env file to git — it is already in .gitignore.
#
# Variables marked [MUST DIFFER] require separate values for staging vs production.
# Variables marked [CAN SHARE] may use the same value across environments.

# ─── OpenAI ────────────────────────────────────────────────────────────────
# [CAN SHARE] API key for OpenAI (used for GPT calls, embeddings, etc.)
OPENAI_API_KEY2=your_openai_api_key_here

# ─── ElevenLabs ────────────────────────────────────────────────────────────
# [CAN SHARE] API key for ElevenLabs text-to-speech voice generation
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ─── Supabase ──────────────────────────────────────────────────────────────
# [MUST DIFFER] Full URL of the Supabase project for this environment.
#   Production:  https://<prod-ref>.supabase.co
#   Staging:     https://<staging-ref>.supabase.co  (separate Supabase project)
SUPABASE_URL=https://your-project-ref.supabase.co

# [MUST DIFFER] Service role key for the Supabase project.
#   This key bypasses Row Level Security — never expose it publicly.
#   Each Supabase project has its own unique service role key.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# [MUST DIFFER] Name of the Supabase Storage bucket used by this environment.
#   Use a clearly named staging bucket (e.g. "sprimal-staging") to avoid
#   any overlap with the production bucket.
SUPABASE_BUCKET=your_bucket_name_here

# ─── Email ─────────────────────────────────────────────────────────────────
# [MUST DIFFER] Gmail (or SMTP) address the app sends emails from.
#   Staging: use a personal/test Gmail account, not the live business account.
EMAIL_USER=your_email@gmail.com

# [MUST DIFFER] App password for the EMAIL_USER account above.
#   Generate via Google Account > Security > App Passwords.
EMAIL_PASS=your_email_app_password_here

# [MUST DIFFER] Recipient email for broker-facing notifications.
#   Production: Cormac's real broker email.
#   Staging:    your own test email address so no test emails reach the client.
BROKER_EMAIL=broker@example.com

# ─── App Passwords ─────────────────────────────────────────────────────────
# [MUST DIFFER] Password for the admin role login.
#   Use a strong unique password in production.
#   Use a simple test password in staging (e.g. "staging-admin-2024").
ADMIN_PASSWORD=your_admin_password_here

# [MUST DIFFER] Password for the senior user role login.
#   Keep distinct from production so staging logins can never access live data.
SENIOR_PASSWORD=your_senior_password_here

# [MUST DIFFER] Password for the junior user role login.
#   Keep distinct from production so staging logins can never access live data.
JUNIOR_PASSWORD=your_junior_password_here
