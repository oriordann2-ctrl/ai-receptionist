# .env.sync.example
# Copy this file to .env.sync and fill in your real values.
# .env.sync is gitignored — your production credentials will never touch GitHub.
#
# Run the sync script with:
#   node scripts/sync-prod-to-staging.js

# ─── Production Supabase (READ ONLY — never written to) ───────────────────────
PROD_SUPABASE_URL=https://your-prod-project-ref.supabase.co
PROD_SUPABASE_SERVICE_ROLE_KEY=your_prod_service_role_key_here
PROD_SUPABASE_BUCKET=your_prod_bucket_name_here

# ─── Staging Supabase (data will be REPLACED with production data) ────────────
STAGING_SUPABASE_URL=https://your-staging-project-ref.supabase.co
STAGING_SUPABASE_SERVICE_ROLE_KEY=your_staging_service_role_key_here
STAGING_SUPABASE_BUCKET=your_staging_bucket_name_here
